---
import Layout from "../layouts/Layout.astro";

const steps = [
  {
    n: "01",
    title: "Escolha seu médico",
    body: "Veja os perfis, as especialidades e escolha com quem você quer se tratar.",
  },
  {
    n: "02",
    title: "Agende pelo WhatsApp",
    body: "Entre em contato direto. Sem formulário, sem espera. A agenda é do médico.",
  },
  {
    n: "03",
    title: "Consulta com tempo",
    body: "Presencial em Ribeirão Preto ou telemedicina. Tempo dedicado, sem pressa.",
  },
];

const services = [
  {
    title: "Consulta inicial",
    body: "Avaliação psiquiátrica completa, sem pressa. Espaço para contar sua história do jeito que ela precisa ser contada.",
  },
  {
    title: "Acompanhamento contínuo",
    body: "Não tratamos episódios. Acompanhamos trajetórias. O vínculo com o médico é parte do tratamento.",
  },
  {
    title: "Telemedicina",
    body: "A mesma qualidade de cuidado, de onde você estiver. Atendimento para todo o Brasil, conforme regulamentação CFM.",
  },
  {
    title: "Segunda opinião",
    body: "Dúvidas sobre diagnóstico ou tratamento em curso? Oferecemos avaliação independente com rigor clínico.",
  },
];

const doctors = [
  {
    name: "Dr. José Augusto Silva Reis",
    crm: "CRM/SP 199536 · RQE 128556",
    specialty: "Esquizofrenia · Reabilitação Psicossocial · Psicodélicos",
    wa: "https://wa.me/5516993732111",
    btnClass: "btn--primary",
  },
  {
    name: "Dr. Lean Pampana Basoli",
    crm: "CRM/SP 199566 · RQE 127180",
    specialty: "Sexualidade · Diversidade de Gênero · Saúde Mental LGBTQIA+",
    wa: "https://wa.me/5516999930259",
    btnClass: "btn--outline",
  },
];
---

<Layout
  title="Consultas — Átris Instituto de Psiquiatria"
  description="Psiquiatria de excelência com tempo e vínculo. Atendimento presencial em Ribeirão Preto e telemedicina para todo o Brasil. Agende diretamente pelo WhatsApp."
>
  <div class="consultas-page">

    <!-- ── Hero ── -->
    <div class="hero">
      <span class="eyebrow">Consultas psiquiátricas</span>
      <h1 class="hero__title">
        Psiquiatria de excelência para quem entende a diferença.
      </h1>
      <p class="hero__sub">
        Atendimento presencial em Ribeirão Preto ou por telemedicina em todo o Brasil.
      </p>
    </div>

    <!-- ── Como funciona ── -->
    <section class="como-funciona">
      <div class="section-inner">
        <span class="eyebrow eyebrow--orange">Como funciona</span>
        <h2 class="section-title">
          Você escolhe o médico. O vínculo começa no primeiro contato.
        </h2>
        <p class="section-body">
          Na Átris, você agenda diretamente com o médico pelo WhatsApp. Sem
          triagem impessoal, sem encaminhamento interno. As consultas acontecem
          com tempo reservado para você — presencialmente em Ribeirão Preto ou
          por telemedicina, onde quer que você esteja.
        </p>

        <span class="divider" aria-hidden="true"></span>

        <div class="steps-grid">
          {steps.map(({ n, title, body }) => (
            <div class="step">
              <span class="step__n">{n}</span>
              <p class="step__title">{title}</p>
              <p class="step__body">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── O que oferecemos ── -->
    <section class="oferecemos">
      <div class="section-inner">
        <span class="eyebrow eyebrow--orange">O que oferecemos</span>
        <h2 class="section-title">
          Cuidado completo, do primeiro contato ao acompanhamento.
        </h2>

        <div class="services-grid">
          {services.map(({ title, body }) => (
            <div class="service-card">
              <p class="service-card__title">{title}</p>
              <p class="service-card__body">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ── CTA final ── -->
    <section class="cta-section">
      <div class="section-inner">
        <span class="eyebrow eyebrow--orange">Agende sua consulta</span>
        <h2 class="section-title">
          Escolha o médico e entre em contato direto.
        </h2>

        <div class="cta-grid">
          {doctors.map(({ name, crm, specialty, wa, btnClass }) => (
            <div class="cta-card">
              <p class="cta-card__name">{name}</p>
              <p class="cta-card__crm">{crm}</p>
              <p class="cta-card__specialty">{specialty}</p>
              <a
                href={wa}
                class:list={["btn", btnClass]}
                target="_blank"
                rel="noopener noreferrer"
              >
                Agendar pelo WhatsApp
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .consultas-page {
    font-family: var(--font-body);
    background: var(--color-bg);
  }

  /* ── Hero ── */
  .hero {
    background: #173f73;
    padding: 72px 24px 64px;
    text-align: center;
  }

  .hero .eyebrow {
    color: #eda27f;
  }

  .hero__title {
    font-size: 38px;
    font-style: italic;
    font-weight: 600;
    color: white;
    max-width: 600px;
    margin: 16px auto 20px;
    line-height: 1.25;
  }

  .hero__sub {
    font-size: 17px;
    font-style: italic;
    color: rgba(255, 255, 255, 0.7);
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.65;
  }

  /* ── Shared ── */
  .eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .eyebrow--orange {
    color: var(--color-orange);
  }

  .section-inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 64px 24px;
  }

  .section-title {
    font-size: 28px;
    font-style: italic;
    font-weight: 400;
    color: var(--color-primary);
    line-height: 1.3;
    margin: 0 0 24px;
  }

  .section-body {
    font-size: 17px;
    font-style: italic;
    color: #444;
    line-height: 1.85;
    margin: 0;
  }

  .divider {
    display: block;
    width: 48px;
    height: 2px;
    background: var(--color-orange);
    margin: 40px 0;
  }

  /* ── Steps ── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 40px;
  }

  .step {
    background: var(--color-card);
    border-radius: 6px;
    padding: 28px 24px;
  }

  .step__n {
    display: block;
    font-size: 11px;
    color: var(--color-orange);
    letter-spacing: 0.18em;
    margin-bottom: 12px;
  }

  .step__title {
    font-size: 17px;
    font-style: italic;
    font-weight: 600;
    color: var(--color-primary);
    line-height: 1.3;
    margin: 0 0 10px;
  }

  .step__body {
    font-size: 13px;
    font-style: italic;
    color: #666;
    line-height: 1.75;
    margin: 0;
  }

  /* ── Oferecemos ── */
  .oferecemos {
    background: var(--color-card);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
    margin-top: 40px;
  }

  .service-card {
    background: var(--color-bg);
    border-radius: 6px;
    padding: 28px 24px;
    border-left: 3px solid var(--color-orange);
  }

  .service-card__title {
    font-size: 18px;
    font-style: italic;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .service-card__body {
    font-size: 13px;
    font-style: italic;
    color: #666;
    line-height: 1.75;
    margin: 0;
  }

  /* ── CTA ── */
  .cta-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 40px;
  }

  .cta-card {
    background: var(--color-card);
    border-radius: 6px;
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .cta-card__name {
    font-size: 18px;
    font-style: italic;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0;
    line-height: 1.3;
  }

  .cta-card__crm {
    font-size: 11px;
    color: #aaa;
    margin: 0;
  }

  .cta-card__specialty {
    font-size: 13px;
    font-style: italic;
    color: #444;
    margin: 0;
    line-height: 1.6;
  }

  .btn {
    padding: 10px 20px;
    font-size: 11px;
    font-family: var(--font-body);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 2px;
    align-self: flex-start;
    transition: opacity var(--transition), background var(--transition), color var(--transition);
  }

  .btn--primary {
    background: var(--color-orange);
    color: #ffffff;
    border: 1px solid var(--color-orange);
  }

  .btn--primary:hover {
    opacity: 0.88;
  }

  .btn--outline {
    background: transparent;
    color: var(--color-primary);
    border: 1px solid rgba(23, 63, 115, 0.4);
  }

  .btn--outline:hover {
    background: var(--color-primary);
    color: #ffffff;
    border-color: var(--color-primary);
  }

  /* ── Responsivo ── */
  @media (max-width: 640px) {
    .hero__title {
      font-size: 28px;
    }

    .steps-grid {
      grid-template-columns: 1fr;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .cta-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

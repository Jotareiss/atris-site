---
import Layout from "../layouts/Layout.astro";

const doctors = [
  {
    photo: "/assets/founders-individual.jpg",
    tag: "Psiquiatra",
    name: "Dr. José Augusto Silva Reis",
    crm: "CRM/SP 199536 · RQE 128556",
    specialties: "Esquizofrenia · Reabilitação Psicossocial · Psicodélicos em Psiquiatria",
    bio: "Graduação e residência em psiquiatria pela FMRP-USP. Doutorando em saúde mental com foco em psicodélicos para transtornos psiquiátricos. Atua no HCRP-USP nos serviços de esquizofrenia e reabilitação psicossocial.",
    wa: "https://wa.me/5516993732111",
    waLabel: "Agendar com Dr. José Augusto",
    placeholder: false,
  },
  {
    photo: "/assets/founders-individual.jpg",
    tag: "Psiquiatra",
    name: "Dr. Lean Pampana Basoli",
    crm: "CRM/SP 199566 · RQE 127180",
    specialties: "Sexualidade · Diversidade de Gênero · Saúde Mental LGBTQIA+",
    bio: "Graduação e residência em psiquiatria pela FMRP-USP. Atua nos ambulatórios de sexualidade e diversidade de gênero do HCRP-USP, no SEAVIDAS-USP e no Hospital Estadual de Américo Brasiliense.",
    wa: "https://wa.me/5516999930259",
    waLabel: "Agendar com Dr. Lean",
    placeholder: false,
  },
  {
    photo: null,
    tag: "Psiquiatra",
    name: "Dra. Lorem Ipsum",
    crm: "CRM/SP 000000 · RQE 000000",
    specialties: "Especialidade · Área de atuação",
    bio: "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Formação e residência pela instituição de referência.",
    wa: "#",
    waLabel: "Em breve",
    placeholder: true,
  },
];
---

<Layout
  title="Médicos — Átris Instituto de Psiquiatria"
  description="Conheça Dr. José Augusto Silva Reis e Dr. Lean Pampana Basoli, psiquiatras formados e residentes pela FMRP-USP. Atendimento presencial em Ribeirão Preto e por telemedicina."
>
  <!-- ── Header ── -->
  <div class="page-header">
    <span class="eyebrow">Nossa equipe</span>
    <h1 class="page-title">Os médicos por trás da Átris.</h1>
    <p class="page-sub">
      Formados e residentes pela FMRP-USP, com atuação no HCRP-USP.
      Dois médicos que decidiram fazer diferente.
    </p>
    <span class="header-rule" aria-hidden="true"></span>
  </div>

  <!-- ── Grid de cards ── -->
  <div class="cards-wrap">
    <div class="cards-grid">
      {doctors.map(({ photo, tag, name, crm, specialties, bio, wa, waLabel, placeholder }) => (
        <article class:list={["card", { "card--placeholder": placeholder }]}>

          <!-- Foto -->
          {photo ? (
            <img src={photo} alt={name} class="card__photo" />
          ) : (
            <div class="card__photo-empty" aria-hidden="true"></div>
          )}

          <!-- Body -->
          <div class="card__body">
            <p class="card__tag">{tag}</p>

            {placeholder && (
              <div class="card__badge">Em breve</div>
            )}

            <h2 class="card__name">{name}</h2>
            <p class="card__crm">{crm}</p>

            <span class="card__rule" aria-hidden="true"></span>

            <p class="card__specialties">{specialties}</p>
            <p class="card__bio">{bio}</p>

            <a
              href={wa}
              class="card__wa"
              target={placeholder ? undefined : "_blank"}
              rel={placeholder ? undefined : "noopener noreferrer"}
              style={placeholder ? "opacity: 0.4; pointer-events: none;" : undefined}
            >
              — {waLabel}
            </a>
          </div>

        </article>
      ))}
    </div>
  </div>
</Layout>

<style>
  /* ── Header ── */
  .page-header {
    max-width: 640px;
    margin: 0 auto;
    padding: 64px 24px 48px;
    text-align: center;
    font-family: var(--font-body);
  }

  .eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin-bottom: 20px;
  }

  .page-title {
    font-size: 36px;
    font-style: italic;
    font-weight: 400;
    color: var(--color-primary);
    line-height: 1.2;
    margin: 0 0 20px;
  }

  .page-sub {
    font-size: 17px;
    font-style: italic;
    color: #666;
    line-height: 1.65;
    margin: 0;
  }

  .header-rule {
    display: block;
    width: 48px;
    height: 2px;
    background: var(--color-orange);
    margin: 40px auto 0;
  }

  /* ── Grid ── */
  .cards-wrap {
    max-width: 1040px;
    margin: 56px auto 0;
    padding: 0 24px 96px;
    font-family: var(--font-body);
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  /* ── Card ── */
  .card {
    background: var(--color-card);
    border-radius: 48px 48px 6px 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .card--placeholder {
    opacity: 0.55;
  }

  .card__photo {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
  }

  .card__photo-empty {
    width: 100%;
    height: 260px;
    background: rgba(237, 162, 127, 0.12);
    border-bottom: 1px dashed rgba(237, 162, 127, 0.3);
  }

  .card__body {
    padding: 24px 24px 28px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card__tag {
    font-size: 10px;
    font-style: italic;
    text-transform: uppercase;
    color: var(--color-salmon);
    margin: 0 0 10px;
    letter-spacing: 0.1em;
  }

  .card__badge {
    background: rgba(237, 162, 127, 0.13);
    border: 1px dashed rgba(237, 162, 127, 0.55);
    border-radius: 3px;
    padding: 6px 12px;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #eda27f;
    text-align: center;
    margin-bottom: 14px;
    align-self: flex-start;
  }

  .card__name {
    font-size: 20px;
    font-style: italic;
    font-weight: 400;
    color: var(--color-primary);
    line-height: 1.2;
    margin: 0 0 6px;
  }

  .card__crm {
    font-size: 11px;
    color: #aaa;
    margin: 0;
    letter-spacing: 0.04em;
  }

  .card__rule {
    display: block;
    width: 32px;
    height: 1.5px;
    background: var(--color-orange);
    margin: 12px 0;
    flex-shrink: 0;
  }

  .card__specialties {
    font-size: 13px;
    font-style: italic;
    color: #444;
    line-height: 1.6;
    margin: 0 0 14px;
  }

  .card__bio {
    font-size: 13px;
    font-style: italic;
    color: #666;
    line-height: 1.75;
    margin: 0 0 20px;
    flex: 1;
  }

  .card__wa {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-orange);
    transition: opacity var(--transition);
    align-self: flex-start;
  }

  .card__wa:hover {
    opacity: 0.7;
  }

  /* ── Responsivo ── */
  @media (max-width: 900px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .card--placeholder {
      display: none;
    }
  }

  @media (max-width: 560px) {
    .cards-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

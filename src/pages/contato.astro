---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contato — Átris Instituto de Psiquiatria"
  description="Entre em contato diretamente com Dr. José Augusto ou Dr. Lean pelo WhatsApp. Atendimento presencial em Ribeirão Preto e telemedicina para todo o Brasil."
>
  <div class="contato-page">
    <div class="contato-col">

      <span class="eyebrow">Contato</span>

      <h1 class="page-title">Fale com a gente.</h1>

      <span class="divider" aria-hidden="true"></span>

      <p class="body">
        Escolha o médico e entre em contato diretamente pelo WhatsApp. Sem
        triagem, sem formulário. O vínculo começa no primeiro contato.
      </p>

      <div class="buttons">

        <div class="btn-group">
          <a
            href="https://wa.me/5516993732111"
            class="btn btn--primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Dr. José Augusto Silva Reis
          </a>
          <span class="btn-crm">CRM/SP 199536 · RQE 128556</span>
        </div>

        <div class="btn-group">
          <a
            href="https://wa.me/5516999930259"
            class="btn btn--outline"
            target="_blank"
            rel="noopener noreferrer"
          >
            Dr. Lean Pampana Basoli
          </a>
          <span class="btn-crm">CRM/SP 199566 · RQE 127180</span>
        </div>

      </div>

      <p class="note">
        Atendimento presencial em Ribeirão Preto, SP · Telemedicina para todo o Brasil
      </p>

    </div>
  </div>
</Layout>

<style>
  .contato-page {
    background: var(--color-bg);
    font-family: var(--font-body);
  }

  .contato-col {
    max-width: 640px;
    margin: 0 auto;
    padding: 72px 24px 80px;
    text-align: center;
  }

  .eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin-bottom: 20px;
  }

  .page-title {
    font-size: 36px;
    font-style: italic;
    font-weight: 400;
    color: var(--color-primary);
    line-height: 1.2;
    margin: 0;
  }

  .divider {
    display: block;
    width: 48px;
    height: 2px;
    background: var(--color-orange);
    margin: 24px auto;
  }

  .body {
    font-size: 18px;
    font-style: italic;
    line-height: 1.85;
    color: #666;
    margin: 0 0 48px;
  }

  .buttons {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }

  .btn-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 40px;
    font-size: 13px;
    font-family: var(--font-body);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 2px;
    min-width: 320px;
    transition: opacity var(--transition), background var(--transition), color var(--transition);
  }

  .btn--primary {
    background: var(--color-orange);
    color: #ffffff;
    border: 1px solid var(--color-orange);
  }

  .btn--primary:hover {
    opacity: 0.88;
  }

  .btn--outline {
    background: transparent;
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
  }

  .btn--outline:hover {
    background: var(--color-primary);
    color: #ffffff;
  }

  .btn-crm {
    font-size: 11px;
    font-style: italic;
    color: #aaa;
  }

  .note {
    font-size: 13px;
    font-style: italic;
    color: #aaa;
    margin-top: 56px;
    border-top: 1px solid rgba(237, 162, 127, 0.27);
    padding-top: 32px;
  }

  @media (max-width: 400px) {
    .btn {
      min-width: 0;
      width: 100%;
    }
  }
</style>

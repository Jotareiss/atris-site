---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contato — Átris Instituto de Psiquiatria"
  description="Entre em contato diretamente com Dr. José Augusto ou Dr. Lean pelo WhatsApp. Atendimento presencial em Ribeirão Preto e telemedicina para todo o Brasil."
>
  <div class="contato-page">
    <div class="contato-col">

      <span class="eyebrow">Contato</span>

      <h1 class="page-title">Fale com a gente.</h1>

      <span class="divider" aria-hidden="true"></span>

      <p class="body">
        O agendamento é feito por WhatsApp.
      </p>

      <a
        href="https://wa.me/5516993732111?text=Ol%C3%A1%2C%20gostaria%20de%20agendar%20uma%20consulta%20na%20%C3%81tris."
        class="btn btn--primary"
        target="_blank"
        rel="noopener noreferrer"
      >
        Agendar consulta
      </a>

      <p class="support">
        A equipe pode orientar na escolha do médico e na organização do atendimento, de acordo com cada caso e disponibilidade.
      </p>

      <div class="info">
        <p class="info__line">Atendimento presencial · Av. Independência, 3115, sala 20 — Ribeirão Preto, SP</p>
        <p class="info__line">Telemedicina para todo o Brasil</p>
      </div>

    </div>
  </div>
</Layout>

<style>
  .contato-page {
    background: var(--color-bg);
    font-family: var(--font-body);
  }

  .contato-col {
    max-width: 640px;
    margin: 0 auto;
    padding: 72px 24px 80px;
    text-align: center;
  }

  .eyebrow {
    display: block;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-orange);
    margin-bottom: 20px;
  }

  .page-title {
    font-size: 36px;
    font-style: italic;
    font-weight: 400;
    color: var(--color-primary);
    line-height: 1.2;
    margin: 0;
  }

  .divider {
    display: block;
    width: 48px;
    height: 2px;
    background: var(--color-orange);
    margin: 24px auto;
  }

  .body {
    font-size: 18px;
    font-style: italic;
    line-height: 1.85;
    color: #666;
    margin: 0 0 40px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 40px;
    font-size: 13px;
    font-family: var(--font-body);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 2px;
    transition: opacity var(--transition);
  }

  .btn--primary {
    background: var(--color-orange);
    color: #ffffff;
    border: 1px solid var(--color-orange);
  }

  .btn--primary:hover {
    opacity: 0.88;
  }

  .support {
    font-size: 14px;
    font-style: italic;
    color: var(--color-text-secondary);
    line-height: 1.75;
    max-width: 400px;
    margin: 32px auto 0;
  }

  .info {
    margin-top: 48px;
    border-top: 1px solid rgba(237, 162, 127, 0.27);
    padding-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .info__line {
    font-size: 13px;
    font-style: italic;
    color: #aaa;
    margin: 0;
  }

  @media (max-width: 400px) {
    .btn {
      width: 100%;
    }
  }
</style>
